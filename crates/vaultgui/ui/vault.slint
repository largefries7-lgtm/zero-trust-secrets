// Unlocked main view: a header strip (engaged dial + posture chip, idle
// countdown, Settings, Lock now), a filterable record list on the left, and
// the selected record's detail as a centered glass card on the right.
//
// NOTE on `filter`: Slint 1.17 has no string "contains"/array `.filter()`, so
// filtering happens in Rust — the search box's per-keystroke `edited` fires the
// App-level `search(query)` callback, which recomputes `record_names`.
import { Theme } from "theme.slint";
import { Dial, Card, Field, PrimaryButton, GhostButton, SectionLabel, Divider, StatusChip } from "widgets.slint";

export component VaultScreen inherits Rectangle {
    in property <string> posture;
    in property <bool> hardware_bound;
    in property <bool> has_recovery;
    in property <[string]> record_names;
    in-out property <string> filter;
    in property <string> selected;
    in property <string> revealed_value;
    in property <int> clip_remaining;
    in property <int> idle_remaining;
    in property <int> idle_timeout_secs;

    callback select(name: string);
    callback reveal(name: string);
    callback mask();
    callback copy(name: string);
    callback add_secret(name: string, value: string);
    callback rotate(name: string, value: string);
    callback remove(name: string);
    callback lock_now();
    callback search(query: string);
    callback open_settings();

    property <bool> weak-posture: !root.hardware_bound || root.has_recovery;

    property <bool> adding: false;
    property <bool> rotating: false;
    property <bool> confirm-remove: false;
    property <string> add-name-text: "";
    property <string> add-value-text: "";
    property <string> rotate-value-text: "";

    changed selected => {
        root.adding = false;
        root.rotating = false;
        root.confirm-remove = false;
        root.add-name-text = "";
        root.add-value-text = "";
        root.rotate-value-text = "";
    }

    background: Theme.bg-base;

    header := Rectangle {
        x: 0;
        y: 0;
        width: 100%;
        height: 60px;
        background: Theme.bg-raised;

        Rectangle {
            x: 0;
            y: parent.height - 1px;
            width: 100%;
            height: 1px;
            background: Theme.line;
        }

        HorizontalLayout {
            width: 100%;
            height: 100%;
            padding-left: Theme.space-5;
            padding-right: Theme.space-4;
            spacing: Theme.space-3;

            HorizontalLayout {
                spacing: Theme.space-3;
                alignment: start;

                Dial {
                    size: 40px;
                    y: (parent.height - self.height) / 2;
                    engaged: true;
                    caution: root.weak-posture;
                    fraction: root.idle_timeout_secs > 0 ? root.idle_remaining / root.idle_timeout_secs : 1.0;
                    center-glyph: "";
                    center-label: root.idle_remaining > 0
                        ? (floor(root.idle_remaining / 60) + ":" + (mod(root.idle_remaining, 60) < 10 ? "0" : "") + mod(root.idle_remaining, 60))
                        : "\u{221E}";
                }
                StatusChip {
                    y: (parent.height - self.height) / 2;
                    text: root.posture;
                    tone: root.weak-posture ? "amber" : "cyan";
                }
            }

            Rectangle { horizontal-stretch: 1; }

            GhostButton {
                text: "Settings";
                width: 96px;
                y: (parent.height - self.height) / 2;
                clicked => { root.open_settings(); }
            }
            GhostButton {
                text: "Lock now";
                width: 104px;
                y: (parent.height - self.height) / 2;
                clicked => { root.lock_now(); }
            }
        }
    }

    HorizontalLayout {
        x: 0;
        y: header.height;
        width: 100%;
        height: parent.height - header.height;

        // ---- Left: search + record list --------------------------------
        Rectangle {
            width: 264px;
            background: Theme.bg-raised;

            Rectangle {
                x: parent.width - 1px;
                y: 0;
                width: 1px;
                height: 100%;
                background: Theme.line;
            }

            VerticalLayout {
                width: 100%;
                height: 100%;
                padding: Theme.space-3;
                spacing: Theme.space-3;

                Field {
                    placeholder: "Search secrets";
                    text <=> root.filter;
                    edited(text) => { root.search(text); }
                }

                SectionLabel {
                    text: root.record_names.length == 1
                        ? "1 SECRET"
                        : root.record_names.length + " SECRETS";
                }

                Flickable {
                    horizontal-stretch: 1;
                    vertical-stretch: 1;
                    viewport-width: self.width;
                    viewport-height: max(self.height, root.record_names.length * 40px);

                    for name[i] in root.record_names : Rectangle {
                        y: i * 40px;
                        x: 0;
                        width: parent.width;
                        height: 38px;
                        border-radius: Theme.radius-field;
                        background: name == root.selected
                            ? Theme.cyan-soft
                            : (row-touch.has-hover ? Theme.bg-raised : transparent);

                        if name == root.selected: Rectangle {
                            x: 0;
                            y: 6px;
                            width: 3px;
                            height: parent.height - 12px;
                            border-radius: 2px;
                            background: Theme.cyan;
                            drop-shadow-blur: 6px;
                            drop-shadow-color: Theme.cyan-glow;
                        }

                        Text {
                            x: Theme.space-3;
                            width: parent.width - 2 * Theme.space-3;
                            height: 100%;
                            vertical-alignment: center;
                            text: name;
                            color: name == root.selected ? Theme.text-primary : Theme.text-secondary;
                            font-family: Theme.font-ui;
                            font-size: Theme.text-body;
                            font-weight: name == root.selected ? 600 : 400;
                            overflow: elide;
                        }

                        row-touch := TouchArea {
                            clicked => { root.select(name); }
                        }
                    }
                }

                if root.adding: VerticalLayout {
                    spacing: Theme.space-2;

                    add-name := Field { placeholder: "Name"; text <=> root.add-name-text; }
                    add-value := Field { placeholder: "Value"; masked: true; text <=> root.add-value-text; }

                    PrimaryButton {
                        text: "Save secret";
                        clicked => {
                            root.add_secret(add-name.text, add-value.text);
                            root.adding = false;
                            root.add-name-text = "";
                            root.add-value-text = "";
                        }
                    }
                }

                GhostButton {
                    text: root.adding ? "Cancel" : "+ Add secret";
                    clicked => { root.adding = !root.adding; }
                }
            }
        }

        // ---- Right: selected record detail -----------------------------
        Rectangle {
            horizontal-stretch: 1;
            background: Theme.bg-base;

            // Empty state — an invitation, with a dormant dial watermark.
            if root.selected == "": VerticalLayout {
                width: 100%;
                height: 100%;
                alignment: center;
                spacing: Theme.space-4;

                HorizontalLayout {
                    alignment: center;
                    Dial {
                        size: 56px;
                        engaged: false;
                        center-glyph: "\u{1F512}";
                        center-label: "";
                    }
                }
                Text {
                    text: "Select a secret";
                    color: Theme.text-secondary;
                    font-family: Theme.font-ui;
                    font-size: Theme.text-title;
                    font-weight: Theme.weight-title;
                    horizontal-alignment: center;
                }
                Text {
                    text: "Pick one from the list, or add a new secret.";
                    color: Theme.text-faint;
                    font-family: Theme.font-ui;
                    font-size: Theme.text-body;
                    horizontal-alignment: center;
                }
            }

            // Selected — a focused glass card, centered.
            if root.selected != "": HorizontalLayout {
                width: 100%;
                height: 100%;
                alignment: center;
                padding: Theme.space-8;

                VerticalLayout {
                    alignment: center;

                    Card {
                        width: 560px;

                        VerticalLayout {
                            padding: Theme.space-6;
                            spacing: Theme.space-4;

                            Text {
                                text: root.selected;
                                color: Theme.text-primary;
                                font-family: Theme.font-ui;
                                font-size: Theme.text-display;
                                font-weight: Theme.weight-display;
                                overflow: elide;
                            }

                            VerticalLayout {
                                spacing: Theme.space-2;

                                SectionLabel { text: "SECRET VALUE"; }

                                Rectangle {
                                    height: 58px;
                                    background: Theme.bg-inset;
                                    border-radius: Theme.radius-field;
                                    border-width: 1px;
                                    border-color: root.revealed_value == "" ? Theme.glass-border : Theme.cyan;
                                    drop-shadow-blur: root.revealed_value == "" ? 0px : 12px;
                                    drop-shadow-color: Theme.cyan-glow;

                                    Text {
                                        x: Theme.space-4;
                                        width: parent.width - 2 * Theme.space-4;
                                        height: 100%;
                                        vertical-alignment: center;
                                        text: root.revealed_value == "" ? "\u{2022}\u{2022}\u{2022}\u{2022}\u{2022}\u{2022}\u{2022}\u{2022}\u{2022}\u{2022}\u{2022}\u{2022}" : root.revealed_value;
                                        color: root.revealed_value == "" ? Theme.text-faint : Theme.text-primary;
                                        font-family: Theme.font-mono;
                                        font-size: Theme.text-mono-lg;
                                        font-weight: Theme.weight-mono-lg;
                                        overflow: elide;
                                    }
                                }
                            }

                            HorizontalLayout {
                                spacing: Theme.space-2;

                                PrimaryButton {
                                    text: root.revealed_value == "" ? "Reveal" : "Hide";
                                    clicked => {
                                        if root.revealed_value == "" {
                                            root.reveal(root.selected);
                                        } else {
                                            root.mask();
                                        }
                                    }
                                }
                                GhostButton {
                                    text: root.clip_remaining > 0 ? "Copied \u{00B7} " + root.clip_remaining + "s" : "Copy";
                                    active: root.clip_remaining > 0;
                                    clicked => { root.copy(root.selected); }
                                }
                            }

                            Divider {}

                            HorizontalLayout {
                                spacing: Theme.space-2;

                                GhostButton {
                                    text: root.rotating ? "Cancel" : "Rotate";
                                    clicked => { root.rotating = !root.rotating; }
                                }
                                GhostButton {
                                    danger: true;
                                    text: root.confirm-remove ? "Confirm remove?" : "Remove";
                                    clicked => {
                                        if root.confirm-remove {
                                            root.remove(root.selected);
                                            root.confirm-remove = false;
                                        } else {
                                            root.confirm-remove = true;
                                        }
                                    }
                                }
                            }

                            if root.rotating: HorizontalLayout {
                                spacing: Theme.space-2;

                                rotate-value := Field { placeholder: "New value"; masked: true; text <=> root.rotate-value-text; }
                                PrimaryButton {
                                    text: "Save";
                                    width: 96px;
                                    clicked => {
                                        root.rotate(root.selected, rotate-value.text);
                                        root.rotating = false;
                                        root.rotate-value-text = "";
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
