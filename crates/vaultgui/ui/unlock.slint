// Unlock screen: centered column with the dormant posture seal, a vault-path
// picker, a masked passphrase field, and a recovery-passphrase alternate.
// Pre-unlock the eyebrow is always "· UNVERIFIED" in `caution` when
// `posture_authenticated` is false (App/Rust sets that flag).
import { Theme } from "theme.slint";

component Seal inherits Rectangle {
    // Locked screen: always the dormant hollow ring (design-system.md
    // "locked vs unlocked treatment") — no engaged/caution state pre-unlock.
    width: 28px;
    height: 28px;
    border-radius: self.width / 2;
    background: transparent;
    border-width: 2px;
    border-color: Theme.accent-dim;
}

component PrimaryButton inherits TouchArea {
    in property <string> text;
    height: 40px;

    Rectangle {
        width: 100%;
        height: 100%;
        border-radius: Theme.radius-field;
        background: root.enabled ? Theme.accent : Theme.accent-dim;
        opacity: root.has-hover && root.enabled ? 0.88 : 1.0;

        Text {
            text: root.text;
            color: Theme.on-accent;
            font-family: Theme.font-ui;
            font-size: Theme.text-body;
            font-weight: 600;
            horizontal-alignment: center;
            vertical-alignment: center;
            width: 100%;
            height: 100%;
        }
    }
}

component GhostButton inherits TouchArea {
    in property <string> text;
    height: 32px;

    Rectangle {
        width: 100%;
        height: 100%;
        border-radius: Theme.radius-field;
        border-width: 1px;
        border-color: Theme.line;
        background: root.has-hover ? Theme.bg-inset : transparent;

        Text {
            text: root.text;
            color: Theme.text-secondary;
            font-family: Theme.font-ui;
            font-size: Theme.text-body;
            horizontal-alignment: center;
            vertical-alignment: center;
            width: 100%;
            height: 100%;
        }
    }
}

// Masked passphrase field. `text` is read once by the caller when the
// Unlock button is pressed / Enter is accepted; nothing here persists it
// beyond the field itself (Task D3 marshals it to `SecretString` and the
// underlying TextInput buffer is dropped with the field).
component MaskedField inherits Rectangle {
    in property <string> placeholder;
    in-out property <string> text <=> input.text;
    callback accepted();

    height: 40px;
    background: Theme.bg-inset;
    border-radius: Theme.radius-field;
    border-width: 1px;
    border-color: input.has-focus ? Theme.accent : Theme.line;

    input := TextInput {
        x: Theme.space-3;
        width: parent.width - 2 * Theme.space-3;
        height: 100%;
        vertical-alignment: center;
        input-type: password;
        color: Theme.text-primary;
        font-family: Theme.font-ui;
        font-size: Theme.text-body;
        accepted => { root.accepted(); }
    }

    if input.text == "" && !input.has-focus: Text {
        x: Theme.space-3;
        width: parent.width - 2 * Theme.space-3;
        height: 100%;
        vertical-alignment: center;
        text: root.placeholder;
        color: Theme.text-faint;
        font-family: Theme.font-ui;
        font-size: Theme.text-body;
    }
}

export component UnlockScreen inherits Rectangle {
    in property <string> vault_path;
    in property <string> posture;
    in property <bool> posture_authenticated;

    callback pick_vault();
    callback unlock(passphrase: string, recovery: bool);

    // Local-only: which field mode ("Unlock" vs "Use recovery passphrase")
    // is active. Never leaves this component.
    property <bool> use-recovery: false;

    background: Theme.bg-base;

    VerticalLayout {
        width: 100%;
        height: 100%;
        alignment: center;

        HorizontalLayout {
            alignment: center;

            VerticalLayout {
                width: 360px;
                spacing: Theme.space-4;

                HorizontalLayout {
                    spacing: Theme.space-2;
                    alignment: center;

                    Seal {}

                    VerticalLayout {
                        alignment: center;
                        spacing: 0px;

                        Text {
                            text: root.posture;
                            color: Theme.accent-dim;
                            font-family: Theme.font-ui;
                            font-size: Theme.text-label;
                            font-weight: Theme.weight-label;
                            letter-spacing: Theme.label-letterspacing;
                        }
                        if !root.posture_authenticated: Text {
                            text: "· UNVERIFIED";
                            color: Theme.caution;
                            font-family: Theme.font-ui;
                            font-size: Theme.text-label;
                            font-weight: Theme.weight-label;
                            letter-spacing: Theme.label-letterspacing;
                        }
                    }
                }

                Text {
                    text: "Unlock vault";
                    color: Theme.text-primary;
                    font-family: Theme.font-ui;
                    font-size: Theme.text-display;
                    font-weight: Theme.weight-display;
                    horizontal-alignment: center;
                }

                VerticalLayout {
                    spacing: Theme.space-1;

                    Text {
                        text: "VAULT";
                        color: Theme.text-faint;
                        font-family: Theme.font-ui;
                        font-size: Theme.text-label;
                        font-weight: Theme.weight-label;
                        letter-spacing: Theme.label-letterspacing;
                    }

                    HorizontalLayout {
                        spacing: Theme.space-2;

                        Rectangle {
                            horizontal-stretch: 1;
                            height: 32px;
                            background: Theme.bg-inset;
                            border-radius: Theme.radius-field;
                            border-width: 1px;
                            border-color: Theme.line;

                            Text {
                                x: Theme.space-2;
                                width: parent.width - 2 * Theme.space-2;
                                height: 100%;
                                vertical-alignment: center;
                                text: root.vault_path == "" ? "No vault selected" : root.vault_path;
                                color: root.vault_path == "" ? Theme.text-faint : Theme.text-secondary;
                                font-family: Theme.font-mono;
                                font-size: Theme.text-mono;
                                overflow: elide;
                            }
                        }

                        GhostButton {
                            text: "Choose…";
                            width: 90px;
                            clicked => { root.pick_vault(); }
                        }
                    }
                }

                pw-field := MaskedField {
                    placeholder: root.use-recovery ? "Recovery code" : "Passphrase";
                    accepted => { root.unlock(self.text, root.use-recovery); }
                }

                PrimaryButton {
                    text: "Unlock";
                    clicked => { root.unlock(pw-field.text, root.use-recovery); }
                }

                GhostButton {
                    text: root.use-recovery ? "Use regular passphrase" : "Use recovery code";
                    clicked => { root.use-recovery = !root.use-recovery; }
                }
            }
        }
    }
}
