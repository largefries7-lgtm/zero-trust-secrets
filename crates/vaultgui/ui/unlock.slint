// Unlock screen: a single centered "unlock panel" card — the dormant hero
// dial, the vault path + picker, a masked passphrase, and a recovery alternate.
// Pre-unlock the posture chip row carries an amber "UNVERIFIED" chip since the
// header it's read from hasn't been authenticated yet.
import { Theme } from "theme.slint";
import { Dial, Card, Field, PrimaryButton, GhostButton, SectionLabel, StatusChip } from "widgets.slint";

export component UnlockScreen inherits Rectangle {
    in property <string> vault_path;
    in property <string> posture;
    in property <bool> posture_authenticated;

    callback pick_vault();
    callback unlock(passphrase: string, recovery: bool);

    property <bool> use-recovery: false;

    background: Theme.bg-base;

    HorizontalLayout {
        alignment: center;

        VerticalLayout {
            alignment: center;

            Card {
                width: 400px;

                VerticalLayout {
                    padding: Theme.space-8;
                    spacing: Theme.space-5;

                    HorizontalLayout {
                        alignment: center;
                        Dial {
                            size: 96px;
                            engaged: false;
                            center-glyph: "\u{1F512}";
                            center-label: "LOCKED";
                        }
                    }

                    HorizontalLayout {
                        alignment: center;
                        spacing: Theme.space-2;

                        StatusChip {
                            text: root.posture == "" ? "NO VAULT" : root.posture;
                            tone: "cyan";
                        }
                        if !root.posture_authenticated: StatusChip {
                            text: "UNVERIFIED";
                            tone: "amber";
                        }
                    }

                    Text {
                        text: "UNLOCK VAULT";
                        font-family: Theme.font-ui;
                        font-size: Theme.text-display;
                        font-weight: Theme.weight-display;
                        color: Theme.text-primary;
                        horizontal-alignment: center;
                        letter-spacing: 2px;
                    }

                    VerticalLayout {
                        spacing: Theme.space-2;

                        SectionLabel { text: "VAULT FILE"; }

                        HorizontalLayout {
                            spacing: Theme.space-2;

                            Rectangle {
                                horizontal-stretch: 1;
                                height: 38px;
                                background: Theme.bg-inset;
                                border-radius: Theme.radius-field;
                                border-width: 1px;
                                border-color: Theme.glass-border;

                                Text {
                                    x: Theme.space-3;
                                    width: parent.width - 2 * Theme.space-3;
                                    height: 100%;
                                    vertical-alignment: center;
                                    text: root.vault_path == "" ? "No vault selected" : root.vault_path;
                                    color: root.vault_path == "" ? Theme.text-faint : Theme.text-secondary;
                                    font-family: Theme.font-mono;
                                    font-size: Theme.text-small;
                                    overflow: elide;
                                }
                            }

                            GhostButton {
                                text: "Choose\u{2026}";
                                width: 96px;
                                clicked => { root.pick_vault(); }
                            }
                        }
                    }

                    pw := Field {
                        placeholder: root.use-recovery ? "Recovery passphrase" : "Passphrase";
                        masked: true;
                        accepted => { root.unlock(self.text, root.use-recovery); }
                    }

                    PrimaryButton {
                        text: "UNLOCK";
                        clicked => { root.unlock(pw.text, root.use-recovery); }
                    }

                    HorizontalLayout {
                        alignment: center;
                        GhostButton {
                            text: root.use-recovery ? "Use regular passphrase" : "Use recovery key";
                            width: 240px;
                            clicked => { root.use-recovery = !root.use-recovery; }
                        }
                    }
                }
            }
        }
    }
}
