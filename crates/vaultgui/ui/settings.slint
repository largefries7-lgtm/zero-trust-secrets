// Settings: a scrollable stack of carded sections — security posture readout,
// the opt-in Windows Hello reveal gate, auto-lock, appearance, the password
// generator, and the typed-DELETE-gated TPM deprovision. Scrollable so it never
// clips on a short/un-maximized window.
import { Theme } from "theme.slint";
import { Card, Field, PrimaryButton, GhostButton, Checkbox, SectionLabel, Divider } from "widgets.slint";

component DangerButton inherits TouchArea {
    in property <string> text;
    height: 42px;
    Rectangle {
        width: 100%;
        height: 100%;
        border-radius: Theme.radius-field;
        background: root.enabled ? Theme.danger : Theme.bg-inset;
        opacity: root.enabled ? (root.has-hover ? 0.9 : 1.0) : 1.0;
        Text {
            text: root.text;
            color: root.enabled ? Theme.on-danger : Theme.text-faint;
            font-family: Theme.font-ui;
            font-size: Theme.text-body;
            font-weight: 700;
            horizontal-alignment: center;
            vertical-alignment: center;
            width: 100%;
            height: 100%;
        }
    }
}

component ReadoutRow {
    in property <string> label;
    in property <string> value;
    in property <brush> value-color: Theme.text-primary;

    HorizontalLayout {
        spacing: Theme.space-4;
        alignment: start;

        SectionLabel {
            text: root.label;
            width: 150px;
        }
        Text {
            text: root.value;
            color: root.value-color;
            font-family: Theme.font-mono;
            font-size: Theme.text-mono;
            horizontal-stretch: 1;
            wrap: word-wrap;
        }
    }
}

export component SettingsScreen inherits Rectangle {
    in property <bool> hardware_bound;
    in property <string> posture;
    in property <bool> has_recovery;
    in property <string> provider_desc;
    in property <int> idle_timeout_secs;
    in property <bool> dark;
    in property <bool> hello_available;
    in property <bool> hello_enabled;
    in property <string> generated_value;

    callback set_timeout(secs: int);
    callback set_dark(value: bool);
    callback set_hello(value: bool);
    callback generate(length: int, symbols: bool);
    callback deprovision();
    callback copy_generated();
    callback close_settings();

    property <int> gen-length: 20;
    property <bool> gen-symbols: true;

    background: Theme.bg-base;

    header := Rectangle {
        x: 0;
        y: 0;
        width: 100%;
        height: 60px;
        background: Theme.bg-raised;

        Rectangle {
            x: 0;
            y: parent.height - 1px;
            width: 100%;
            height: 1px;
            background: Theme.line;
        }

        HorizontalLayout {
            width: 100%;
            height: 100%;
            padding-left: Theme.space-6;
            padding-right: Theme.space-4;
            spacing: Theme.space-3;

            Text {
                text: "Settings";
                color: Theme.text-primary;
                font-family: Theme.font-ui;
                font-size: Theme.text-title;
                font-weight: Theme.weight-title;
                horizontal-stretch: 1;
                vertical-alignment: center;
            }
            GhostButton {
                text: "Back to vault";
                width: 128px;
                y: (parent.height - self.height) / 2;
                clicked => { root.close_settings(); }
            }
        }
    }

    Flickable {
        x: 0;
        y: header.height;
        width: 100%;
        height: parent.height - header.height;
        viewport-width: self.width;
        viewport-height: content.preferred-height;

        content := VerticalLayout {
            width: parent.width;
            padding: Theme.space-6;
            spacing: Theme.space-4;

            // ---- Security posture ----
            Card {
                VerticalLayout {
                    padding: Theme.space-5;
                    spacing: Theme.space-4;

                    SectionLabel { text: "SECURITY POSTURE"; }
                    ReadoutRow {
                        label: "HARDWARE BINDING";
                        value: root.hardware_bound ? "TPM-bound" : "Passphrase only — no hardware binding";
                        value-color: root.hardware_bound ? Theme.text-primary : Theme.caution;
                    }
                    ReadoutRow { label: "FACTORS"; value: root.posture; }
                    ReadoutRow {
                        label: "RECOVERY ESCROW";
                        value: root.has_recovery
                            ? "Enabled — a stolen vault is only as strong as the recovery passphrase"
                            : "Disabled";
                        value-color: root.has_recovery ? Theme.caution : Theme.text-primary;
                    }
                    ReadoutRow { label: "PROVIDER"; value: root.provider_desc; }
                }
            }

            // ---- Windows Hello ----
            Card {
                VerticalLayout {
                    padding: Theme.space-5;
                    spacing: Theme.space-2;

                    Checkbox {
                        text: "Require Windows Hello before revealing a secret";
                        checked: root.hello_enabled;
                        enabled: root.hello_available;
                        clicked => { root.set_hello(!root.hello_enabled); }
                    }
                    Text {
                        text: root.hello_available
                            ? "Gates revealing a secret's value on screen. It does not protect the vault key — the passphrase (and TPM, if bound) is unchanged."
                            : "Windows Hello isn't available on this device, so this gate can't be enforced.";
                        color: Theme.text-faint;
                        font-family: Theme.font-ui;
                        font-size: Theme.text-small;
                        wrap: word-wrap;
                    }
                }
            }

            // ---- Auto-lock ----
            Card {
                VerticalLayout {
                    padding: Theme.space-5;
                    spacing: Theme.space-3;

                    SectionLabel { text: "AUTO-LOCK"; }
                    HorizontalLayout {
                        spacing: Theme.space-2;
                        GhostButton { text: "1 min"; active: root.idle_timeout_secs == 60; clicked => { root.set_timeout(60); } }
                        GhostButton { text: "5 min"; active: root.idle_timeout_secs == 300; clicked => { root.set_timeout(300); } }
                        GhostButton { text: "15 min"; active: root.idle_timeout_secs == 900; clicked => { root.set_timeout(900); } }
                        GhostButton { text: "30 min"; active: root.idle_timeout_secs == 1800; clicked => { root.set_timeout(1800); } }
                    }
                    Text {
                        text: "Locks after this much inactivity, or immediately on Windows lock (Win+L) or sleep. Timeout changes take effect on the next launch.";
                        color: Theme.text-faint;
                        font-family: Theme.font-ui;
                        font-size: Theme.text-small;
                        wrap: word-wrap;
                    }
                }
            }

            // ---- Appearance ----
            Card {
                VerticalLayout {
                    padding: Theme.space-5;
                    spacing: Theme.space-3;

                    SectionLabel { text: "APPEARANCE"; }
                    HorizontalLayout {
                        spacing: Theme.space-2;
                        GhostButton { text: "Light"; active: !root.dark; clicked => { root.set_dark(false); } }
                        GhostButton { text: "Dark"; active: root.dark; clicked => { root.set_dark(true); } }
                    }
                }
            }

            // ---- Password generator ----
            Card {
                VerticalLayout {
                    padding: Theme.space-5;
                    spacing: Theme.space-3;

                    SectionLabel { text: "PASSWORD GENERATOR"; }
                    HorizontalLayout {
                        spacing: Theme.space-2;

                        GhostButton { text: "−"; width: 40px; clicked => { root.gen-length = max(8, root.gen-length - 4); } }
                        Rectangle {
                            width: 56px;
                            height: 38px;
                            background: Theme.bg-inset;
                            border-radius: Theme.radius-field;
                            border-width: 1px;
                            border-color: Theme.line;
                            Text {
                                text: root.gen-length;
                                color: Theme.text-primary;
                                font-family: Theme.font-mono;
                                font-size: Theme.text-mono;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                width: 100%;
                                height: 100%;
                            }
                        }
                        GhostButton { text: "+"; width: 40px; clicked => { root.gen-length = min(64, root.gen-length + 4); } }
                        Rectangle {
                            width: 12px;
                        }
                        Checkbox {
                            text: "Symbols";
                            checked: root.gen-symbols;
                            y: (parent.height - self.height) / 2;
                            clicked => { root.gen-symbols = !root.gen-symbols; }
                        }
                        Rectangle { horizontal-stretch: 1; }
                        PrimaryButton { text: "Generate"; width: 120px; clicked => { root.generate(root.gen-length, root.gen-symbols); } }
                    }

                    if root.generated_value != "": HorizontalLayout {
                        spacing: Theme.space-2;

                        Rectangle {
                            horizontal-stretch: 1;
                            height: 46px;
                            background: Theme.bg-inset;
                            border-radius: Theme.radius-field;
                            border-width: 1px;
                            border-color: Theme.accent;
                            TextInput {
                                x: Theme.space-4;
                                width: parent.width - 2 * Theme.space-4;
                                height: 100%;
                                vertical-alignment: center;
                                text: root.generated_value;
                                read-only: true;
                                color: Theme.text-primary;
                                font-family: Theme.font-mono;
                                font-size: Theme.text-mono-lg;
                                font-weight: Theme.weight-mono-lg;
                            }
                        }
                        GhostButton { text: "Copy"; width: 96px; clicked => { root.copy_generated(); } }
                    }
                }
            }

            // ---- Deprovision ----
            Card {
                border-color: Theme.danger;
                VerticalLayout {
                    padding: Theme.space-5;
                    spacing: Theme.space-3;

                    SectionLabel { text: "DEPROVISION TPM KEY"; color: Theme.danger; }
                    Text {
                        text: "Deletes this machine's TPM wrapping key. Every TPM-bound vault becomes undecryptable via the TPM afterward — a vault's recovery passphrase, if set, still works.";
                        color: Theme.text-secondary;
                        font-family: Theme.font-ui;
                        font-size: Theme.text-body;
                        wrap: word-wrap;
                    }
                    HorizontalLayout {
                        spacing: Theme.space-2;
                        confirm-field := Field { placeholder: "Type DELETE to confirm"; }
                        DangerButton {
                            text: "Deprovision";
                            width: 160px;
                            enabled: confirm-field.text == "DELETE";
                            clicked => { root.deprovision(); }
                        }
                    }
                }
            }
        }
    }
}
