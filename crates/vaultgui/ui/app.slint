// Root state machine. `App` is the Rust<->Slint contract surface (Task D3
// binds to these exact property/callback names — do not rename): it
// switches on `screen` and wires each screen's local callbacks up to the
// App-level callbacks Rust handles, and forwards the properties each screen
// needs back down. All colors/fonts/spacing route through `Theme` (D1).
import { Theme } from "theme.slint";
import { CreateScreen } from "create.slint";
import { UnlockScreen } from "unlock.slint";
import { VaultScreen } from "vault.slint";
import { SettingsScreen } from "settings.slint";

export component App inherits Window {
    title: "Zero-Trust Secrets";
    preferred-width: 980px;
    preferred-height: 640px;
    background: Theme.bg-base;

    // ---- Screen selection ("create" | "unlock" | "vault" | "settings") ---
    in-out property <string> screen: "unlock";

    // ---- Light/dark preference, mirrored onto the Theme global -----------
    in-out property <bool> dark <=> Theme.dark;

    // ---- Vault identity / posture -----------------------------------------
    in-out property <string> vault_path;
    in-out property <string> posture;
    in-out property <bool> posture_authenticated: false;
    in-out property <bool> hardware_bound: false;
    in-out property <bool> has_recovery: false;
    in-out property <string> provider_desc;

    // ---- Records -----------------------------------------------------
    in-out property <[string]> record_names;
    in-out property <string> filter;
    in-out property <string> selected;
    in-out property <string> revealed_value;
    in-out property <string> generated_value;

    // ---- Timers ---------------------------------------------------------
    in-out property <int> clip_remaining: 0;
    in-out property <int> idle_remaining: 0;
    in-out property <int> idle_timeout_secs: 0;

    // ---- Capabilities / errors ---------------------------------------------
    in-out property <bool> hello_available: false;
    in-out property <bool> hello_enabled: false;
    in-out property <string> error;

    // ---- Callbacks (handled in Rust; see src/main.rs, Task D3) -------------
    callback pick_vault();
    callback create_vault(passphrase: string, confirm: string, allow_no_tpm: bool, use_recovery: bool, recovery_passphrase: string);
    callback unlock(passphrase: string, recovery: bool);
    callback select(name: string);
    callback reveal(name: string);
    callback mask();
    callback copy(name: string);
    callback add_secret(name: string, value: string);
    callback rotate(name: string, value: string);
    callback remove(name: string);
    callback generate(length: int, symbols: bool);
    callback lock_now();
    callback set_timeout(secs: int);
    callback set_dark(value: bool);
    callback deprovision();
    callback search(query: string);
    callback copy_generated();
    callback set_hello(value: bool);

    if root.screen == "create" : CreateScreen {
        x: 0;
        y: 0;
        width: 100%;
        height: 100%;

        // Fade in on switch: `if` re-instantiates the screen, `init` flips
        // opacity 0->1 which the `animate` picks up (a constant opacity:1
        // would have nothing to animate from).
        opacity: 0;
        init => { self.opacity = 1; }
        animate opacity { duration: 200ms; easing: ease-out; }

        create_vault(passphrase, confirm, allow_no_tpm, use_recovery, recovery_passphrase) => {
            root.create_vault(passphrase, confirm, allow_no_tpm, use_recovery, recovery_passphrase);
        }
    }

    if root.screen == "unlock" : UnlockScreen {
        x: 0;
        y: 0;
        width: 100%;
        height: 100%;

        opacity: 0;
        init => { self.opacity = 1; }
        animate opacity { duration: 200ms; easing: ease-out; }

        vault_path: root.vault_path;
        posture: root.posture;
        posture_authenticated: root.posture_authenticated;

        pick_vault => { root.pick_vault(); }
        unlock(passphrase, recovery) => { root.unlock(passphrase, recovery); }
    }

    if root.screen == "vault" : VaultScreen {
        x: 0;
        y: 0;
        width: 100%;
        height: 100%;

        opacity: 0;
        init => { self.opacity = 1; }
        animate opacity { duration: 200ms; easing: ease-out; }

        posture: root.posture;
        hardware_bound: root.hardware_bound;
        has_recovery: root.has_recovery;
        record_names: root.record_names;
        filter <=> root.filter;
        selected: root.selected;
        revealed_value: root.revealed_value;
        clip_remaining: root.clip_remaining;
        idle_remaining: root.idle_remaining;
        idle_timeout_secs: root.idle_timeout_secs;

        select(name) => { root.select(name); }
        reveal(name) => { root.reveal(name); }
        mask => { root.mask(); }
        copy(name) => { root.copy(name); }
        add_secret(name, value) => { root.add_secret(name, value); }
        rotate(name, value) => { root.rotate(name, value); }
        remove(name) => { root.remove(name); }
        lock_now => { root.lock_now(); }
        search(query) => { root.search(query); }
        open_settings => { root.screen = "settings"; }
    }

    if root.screen == "settings" : SettingsScreen {
        x: 0;
        y: 0;
        width: 100%;
        height: 100%;

        opacity: 0;
        init => { self.opacity = 1; }
        animate opacity { duration: 200ms; easing: ease-out; }

        hardware_bound: root.hardware_bound;
        posture: root.posture;
        has_recovery: root.has_recovery;
        provider_desc: root.provider_desc;
        idle_timeout_secs: root.idle_timeout_secs;
        dark: root.dark;
        hello_available: root.hello_available;
        hello_enabled: root.hello_enabled;
        generated_value: root.generated_value;

        set_timeout(secs) => { root.set_timeout(secs); }
        set_dark(value) => { root.set_dark(value); }
        set_hello(value) => { root.set_hello(value); }
        generate(length, symbols) => { root.generate(length, symbols); }
        deprovision => { root.deprovision(); }
        copy_generated => { root.copy_generated(); }
        close_settings => { root.screen = "vault"; }
    }

    // Dismissable error toast: a floating rounded card near the top, always on
    // top (declared last = highest z-order among siblings). Fades in on appear.
    if root.error != "" : Rectangle {
        width: min(parent.width - 2 * Theme.space-6, 560px);
        height: 48px;
        x: (parent.width - self.width) / 2;
        y: Theme.space-5;
        background: Theme.danger;
        border-radius: Theme.radius-field;
        drop-shadow-blur: 28px;
        drop-shadow-color: #00000080;
        drop-shadow-offset-y: 8px;

        opacity: 0;
        init => { self.opacity = 1; }
        animate opacity { duration: 200ms; easing: ease-out; }

        HorizontalLayout {
            width: 100%;
            height: 100%;
            padding-left: Theme.space-4;
            padding-right: Theme.space-3;
            spacing: Theme.space-3;

            Text {
                text: root.error;
                color: Theme.on-danger;
                font-family: Theme.font-ui;
                font-size: Theme.text-body;
                font-weight: 600;
                vertical-alignment: center;
                horizontal-stretch: 1;
                overflow: elide;
            }

            TouchArea {
                width: 24px;
                clicked => { root.error = ""; }

                Text {
                    text: "×";
                    color: Theme.on-danger;
                    font-size: Theme.text-title;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    width: 100%;
                    height: 100%;
                }
            }
        }
    }
}
