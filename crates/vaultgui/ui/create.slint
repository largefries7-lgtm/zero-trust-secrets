// First-run screen: two-factor vs --allow-no-tpm choice (same honest tradeoff
// wording as the CLI), optional recovery escrow, passphrase + confirm. Emits a
// single `create_vault` callback carrying everything so no long-lived property
// holds a secret. Scrollable so a tall form never clips on a short window.
import { Theme } from "theme.slint";
import { Dial, Card, Field, PrimaryButton, Checkbox, SectionLabel } from "widgets.slint";

// One security-model choice card (two-factor vs --allow-no-tpm). `selected` and
// `tradeoff-color` are caller-driven; the caller handles `clicked`.
component Choice inherits TouchArea {
    in property <string> title;
    in property <string> tradeoff;
    in property <bool> selected: false;
    in property <brush> tradeoff-color: Theme.text-secondary;
    height: 88px;

    Rectangle {
        width: 100%;
        height: 100%;
        background: root.selected ? Theme.cyan-soft : Theme.bg-inset;
        border-radius: Theme.radius-panel;
        border-width: root.selected ? 1.5px : 1px;
        border-color: root.selected ? Theme.cyan : Theme.line;
        drop-shadow-blur: root.selected ? 10px : 0px;
        drop-shadow-color: Theme.cyan-glow;

        HorizontalLayout {
            padding: Theme.space-4;
            spacing: Theme.space-3;

            Rectangle {
                width: 18px;
                height: 18px;
                y: 2px;
                border-radius: self.width / 2;
                background: transparent;
                border-width: root.selected ? 6px : 1.5px;
                border-color: root.selected ? Theme.cyan : Theme.line;
            }

            VerticalLayout {
                spacing: Theme.space-1;
                horizontal-stretch: 1;

                Text {
                    text: root.title;
                    color: Theme.text-primary;
                    font-family: Theme.font-ui;
                    font-size: Theme.text-body;
                    font-weight: 600;
                }
                Text {
                    text: root.tradeoff;
                    color: root.tradeoff-color;
                    font-family: Theme.font-ui;
                    font-size: Theme.text-small;
                    wrap: word-wrap;
                }
            }
        }
    }
}

export component CreateScreen inherits Rectangle {
    callback create_vault(passphrase: string, confirm: string, allow_no_tpm: bool, use_recovery: bool, recovery_passphrase: string);

    property <bool> allow-no-tpm: false;
    property <bool> use-recovery: false;

    background: Theme.bg-base;

    Flickable {
        width: 100%;
        height: 100%;
        viewport-width: self.width;
        viewport-height: content.preferred-height;

        content := VerticalLayout {
            width: parent.width;
            padding: Theme.space-8;

            HorizontalLayout {
                alignment: center;

                Card {
                    width: 460px;

                    VerticalLayout {
                        padding: Theme.space-8;
                        spacing: Theme.space-5;

                        HorizontalLayout {
                            spacing: Theme.space-3;
                            Dial { size: 34px; engaged: false; center-label: ""; }
                            Text {
                                text: "Create a vault";
                                color: Theme.text-primary;
                                font-family: Theme.font-ui;
                                font-size: Theme.text-display;
                                font-weight: Theme.weight-display;
                                vertical-alignment: center;
                            }
                        }

                        VerticalLayout {
                            spacing: Theme.space-2;

                            SectionLabel { text: "SECOND FACTOR"; }

                            Choice {
                                title: "Two-factor · TPM + passphrase";
                                tradeoff: "Strongest: unlocking needs this machine's TPM and your passphrase.";
                                selected: !root.allow-no-tpm;
                                tradeoff-color: root.allow-no-tpm ? Theme.text-secondary : Theme.cyan;
                                clicked => { root.allow-no-tpm = false; }
                            }
                            Choice {
                                title: "Passphrase only";
                                tradeoff: "Hardware binding off — anyone with the file and passphrase can decrypt it on any machine.";
                                selected: root.allow-no-tpm;
                                tradeoff-color: Theme.amber;
                                clicked => { root.allow-no-tpm = true; }
                            }
                        }

                        VerticalLayout {
                            spacing: Theme.space-2;

                            Checkbox {
                                text: "Add a recovery escrow";
                                checked: root.use-recovery;
                                clicked => { root.use-recovery = !root.use-recovery; }
                            }
                            if root.use-recovery: Text {
                                text: "Survives TPM loss — but a stolen vault is then only as strong as the recovery passphrase.";
                                color: Theme.amber;
                                font-family: Theme.font-ui;
                                font-size: Theme.text-small;
                                wrap: word-wrap;
                            }
                        }

                        VerticalLayout {
                            spacing: Theme.space-3;

                            pw-field := Field { placeholder: "Passphrase"; masked: true; }
                            confirm-field := Field { placeholder: "Confirm passphrase"; masked: true; }
                            recovery-field := Field {
                                placeholder: "Recovery passphrase";
                                masked: true;
                                field-enabled: root.use-recovery;
                            }
                        }

                        PrimaryButton {
                            text: "Create vault";
                            clicked => {
                                root.create_vault(
                                    pw-field.text,
                                    confirm-field.text,
                                    root.allow-no-tpm,
                                    root.use-recovery,
                                    recovery-field.text,
                                );
                            }
                        }
                    }
                }
            }
        }
    }
}
